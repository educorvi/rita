{
  "$schema": "https://v2-9-16.turborepo.dev/schema.json",
  "ui": "tui",
  "concurrency": "100%",
  "tasks": {
    "build:internal": {
      "outputs": [
        "dist/**"
      ],
      "dependsOn": [
        "^build:internal"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types",
        "^build:internal"
      ]
    },
    "dev:internal": {
      "persistent": true,
      "cache": false,
      "dependsOn": [
        "^build:internal"
      ]
    },
    "lint": {
      "cache": false
    },
    "lint:fix": {
      "cache": false
    },
    "test": {
      "cache": false,
      "dependsOn": [
        "^build:internal"
      ]
    },
    "doc": {
      "outputs": [
        "docs/**"
      ]
    }
  }
}
