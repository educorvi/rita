{
  "name": "@educorvi/rita",
  "version": "5.5.1",
  "description": "JSON Schema for rules that can be used to evaluate data and a Typescript implementation to evaluate those rules",
  "bugs": {
    "url": "https://github.com/educorvi/rita/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/educorvi/rita.git"
  },
  "license": "MIT",
  "author": "Julian Pollinger",
  "sideEffects": false,
  "main": "dist/rita.js",
  "module": "dist/rita.mjs",
  "typings": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "src/schema"
  ],
  "scripts": {
    "check-types": "tsc --noEmit",
    "build": "turbo build:internal check-types",
    "build:validator": "ajv compile --spec=draft2019 -c ajv-formats -s src/schema/schema.json -r src/schema/atom.json -r src/schema/calculation.json -r src/schema/comparison.json -r src/schema/dateCalculation.json -r src/schema/formula.json -r src/schema/macro.json -r src/schema/operator.json -r src/schema/plugin.json -r src/schema/quantifier.json -r src/schema/rule.json -o src/Validator/RitaRulesetAjvValidator.js",
    "build:internal": "npm run build:validator && vite build",
    "doc": "npm run doc:implementation && npm run doc:schema && git add docs",
    "doc:implementation": "npx typedoc --out docs/implementation src/index.ts",
    "doc:schema": "jsonschema2md -d src/schema -o docs/schema -e json -x -",
    "prepack": "yarn run build",
    "test": "vitest run"
  },
  "dependencies": {
    "dayjs": "^1.11.20",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@adobe/jsonschema2md": "^8.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@types/deep-equal": "^1.0.4",
    "@types/madge": "^5.0.3",
    "@types/node": "^24.0.10",
    "@vitest/coverage-v8": "~4.1.8",
    "ajv": "8.18.0",
    "ajv-cli": "~5.0.0",
    "ajv-formats": "^2.1.1",
    "jest-extended": "^6.0.0",
    "madge": "^8.0.0",
    "mkdirp": "^3.0.1",
    "rimraf": "^6.0.1",
    "semantic-release": "^25.0.3",
    "semantic-release-monorepo": "^8.0.2",
    "semantic-release-yarn": "^3.0.2",
    "turbo": "^2.9.16",
    "typedoc": "0.28.7",
    "typescript": "5.8.3",
    "unplugin-dts": "~1.0.0-beta.6",
    "vite": "7.3.5",
    "vite-bundle-analyzer": "~1.3.8",
    "vite-plugin-externalize-deps": "~0.10.0",
    "vitest": "4.1.8"
  },
  "engines": {
    "node": ">=10"
  }
}
