{
  "name": "@educorvi/smtlib",
  "version": "0.0.0",
  "description": "A Javascript wrapper with a Z3-ish API for SMT-LIB 2.6, the language of Satisfiability Modulo Theories solvers",
  "repository": "https://github.com/educorvi/rita",
  "license": "MIT",
  "author": "Julian Pollinger",
  "main": "dist/smtlib.js",
  "module": "dist/smtlib.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "lib"
  ],
  "scripts": {
    "check-types": "tsc --noEmit",
    "build": "turbo build:internal check-types",
    "build:internal": "vite build",
    "coverage": "nyc report --reporter=text-lcov | coveralls",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx ./lib ./test",
    "prepack": "yarn run build",
    "test": ">&2 echo \"No tests defined yet!\""
  },
  "nyc": {
    "extends": "@istanbuljs/nyc-config-typescript"
  },
  "dependencies": {
    "byline": "^5.0.0"
  },
  "devDependencies": {
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@types/byline": "^4.2.36",
    "@types/node": "^24.0.10",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "coveralls": "^3.1.1",
    "eslint": "^10.4.1",
    "nyc": "^18.0.0",
    "semantic-release": "^25.0.3",
    "semantic-release-monorepo": "^8.0.2",
    "semantic-release-yarn": "^3.0.2",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "turbo": "^2.9.16",
    "typedoc": "^0.28.19",
    "typescript": "~6.0.3",
    "unplugin-dts": "~1.0.0-beta.6",
    "vite": "7.3.5",
    "vite-plugin-externalize-deps": "~0.10.0"
  }
}
