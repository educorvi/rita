{
  "name": "@educorvi/persistent-rita",
  "description": "This is a package to persist rita rulesets in a database",
  "version": "0.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/educorvi/rita"
  },
  "license": "MIT",
  "author": "Julian Pollinger",
  "sideEffects": false,
  "main": "dist/persistent-rita.js",
  "module": "dist/persistent-rita.mjs",
  "typings": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "check-types": "tsc --noEmit",
    "prebuild": "rimraf dist",
    "build:internal": "vite build",
    "build": "turbo build:internal check-types",
    "doc": "npx typedoc src/index.ts --out docs",
    "prepack": "yarn run build",
    "test": "vitest run"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@educorvi/rita": "workspace:^",
    "@rollup/plugin-swc": "~0.4.0",
    "@semantic-release/exec": "^7.1.0",
    "@swc/core": "~1.15.3",
    "better-sqlite3": "^12.10.0",
    "dotenv": "17.2.3",
    "mysql2": "^3.22.4",
    "pg": "~8.21.0",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3",
    "semantic-release-monorepo": "^8.0.2",
    "semantic-release-yarn": "^3.0.2",
    "tslib": "^2.8.1",
    "turbo": "^2.9.16",
    "typedoc": "^0.28.19",
    "typeorm": "^1.0.0",
    "typescript": "~6.0.3",
    "unplugin-dts": "~1.0.0-beta.6",
    "vite": "8.0.16",
    "vite-plugin-externalize-deps": "~0.10.0",
    "vitest": "4.1.8"
  },
  "peerDependencies": {
    "@educorvi/rita": "5.5.1",
    "better-sqlite3": "^12.10.0",
    "mysql2": "^3.22.4",
    "pg": "~8.21.0",
    "typeorm": "^1.0.0"
  },
  "engines": {
    "node": ">=14"
  },
  "publishConfig": {
    "access": "public"
  }
}
