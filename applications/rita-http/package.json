{
  "name": "rita-http",
  "version": "0.0.0",
  "private": true,
  "description": "HTTP API for Rita",
  "keywords": [
    "rita",
    "express.js",
    "typescript",
    "api"
  ],
  "homepage": "https://github.com/educorvi/rita/tree/develop/rita-http#readme",
  "bugs": {
    "url": "https://github.com/educorvi/rita/tree/develop/rita-http/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/educorvi/rita.git"
  },
  "license": "MIT",
  "author": "Julian Pollinger",
  "main": "dist/rita-http.cjs",
  "bin": "dist/rita-http.cjs",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "check-types": "tsc --noEmit",
    "prepack": "npm run build",
    "build": "turbo build:internal check-types",
    "build:routes": "yarn run generate-routes && yarn run spec ",
    "build:internal": "vite build",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:config": "ts-node-dev --respawn --transpile-only src/index.ts -- --config",
    "doc": "npm run spec",
    "generate-routes": "npx tsoa routes",
    "spec": "npx tsoa spec",
    "start": "node .",
    "test:no-server": "LOGLEVEL=error vitest run",
    "test": "start-server-and-test start http://localhost:3000 test:no-server"
  },
  "dependencies": {
    "@educorvi/persistent-rita": "workspace:^",
    "@educorvi/rita": "workspace:^",
    "@educorvi/rita-plugin-http": "workspace:^",
    "@tsoa/runtime": "^6.6.0",
    "better-sqlite3": "^12.11.1",
    "body-parser": "^2.3.0",
    "dotenv": "17.4.2",
    "express": "^5.2.1",
    "mysql2": "^3.22.5",
    "pg": "~8.21.0",
    "promise.any": "^2.0.6",
    "reflect-metadata": "^0.2.2",
    "semver": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "terminal-kit": "^3.1.2",
    "tslog": "^4.9.3",
    "tsoa": "^6.6.0",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@rollup/plugin-swc": "~0.4.0",
    "@semantic-release/exec": "^7.1.0",
    "@swc/core": "~1.15.3",
    "@types/body-parser": "^1.19.6",
    "@types/express": "^5.0.6",
    "@types/node": "^24.0.10",
    "@types/semver": "^7.7.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/terminal-kit": "^2.5.7",
    "axios": "^1.17.0",
    "bestzip": "^2.2.1",
    "semantic-release": "^25.0.3",
    "semantic-release-monorepo": "^8.0.2",
    "semantic-release-yarn": "^3.0.2",
    "start-server-and-test": "^2.0.12",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "turbo": "^2.9.16",
    "typescript": "~6.0.3",
    "unplugin-dts": "~1.0.0-beta.6",
    "vite": "7.3.5",
    "vite-plugin-externalize-deps": "~0.10.0",
    "vitest": "4.1.8"
  }
}
