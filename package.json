{
  "name": "rita",
  "packageManager": "yarn@4.16.0",
  "workspaces": [
    "applications/*",
    "packages/**/*"
  ],
  "scripts": {
    "build": "turbo check-types build:internal",
    "test": "turbo test",
    "doc": "turbo doc && cp -r ./packages/rita-core/docs ./docs/rita-core && cp -r ./packages/persistent-rita/docs ./docs/persistent-rita && cp -r ./applications/rita-http/docs ./docs/rita-http",
    "release": "yarn workspaces foreach --topological-dev -Av --exclude . run semantic-release -e semantic-release-monorepo",
    "release:dry-run": "yarn workspaces foreach --topological-dev -Av --exclude . run semantic-release --dry-run -e semantic-release-monorepo",
    "setOldVersions": "yarn workspaces foreach -Apv --exclude . exec $(git rev-parse --show-toplevel)/.github/findAndSetOldVersion.mjs",
    "size": "size-limit"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@size-limit/file": "^12.1.0",
    "@size-limit/preset-big-lib": "^12.1.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@yarnpkg/types": "^4.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "mkdirp": "^3.0.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3",
    "semantic-release-monorepo": "^8.0.2",
    "semantic-release-yarn": "^3.0.2",
    "semver": "^7.8.2",
    "size-limit": "^12.1.0",
    "syncpack": "^15.3.1",
    "turbo": "^2.9.16",
    "typedoc": "^0.28.19",
    "typescript": "~6.0.3",
    "vue-eslint-parser": "^10.4.1"
  }
}
